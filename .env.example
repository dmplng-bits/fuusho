# Copy to .env and fill in, or just run `python init.py` to generate this
# file interactively (recommended — it also copies your .p8 key into
# ./secrets/ with the right permissions).

# Where your phone should reach this server. If you're testing against
# the iOS Simulator, http://127.0.0.1:8090 works. On a real device, use
# your machine's LAN IP or a hostname it can resolve (e.g. Tailscale).
PUBLIC_SERVER_URL=http://localhost:8090

# From developer.apple.com -> Certificates, Identifiers & Profiles -> Keys
# (Apple Push Notifications service key). The .p8 file itself goes in
# ./secrets/ — reference it here as /secrets/<filename>.p8 (that's the
# path *inside* the container, matching the docker-compose volume mount).
APNS_KEY_PATH=/secrets/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=YYYYYYYYYY
APNS_BUNDLE_ID=com.yourname.yourapp

# true for Xcode-installed (development) builds, false for TestFlight/App Store.
APNS_USE_SANDBOX=true

# Optional — leave blank to skip.
INTERNAL_API_SECRET=
NTFY_URL=
NTFY_TOKEN=
